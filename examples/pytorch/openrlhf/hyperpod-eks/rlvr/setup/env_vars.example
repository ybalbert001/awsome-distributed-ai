# Docker image
export AWS_REGION=$(aws ec2 describe-availability-zones --output text --query 'AvailabilityZones[0].[RegionName]')
export ACCOUNT=$(aws sts get-caller-identity --query Account --output text)
export REGISTRY=${ACCOUNT}.dkr.ecr.${AWS_REGION}.amazonaws.com/
export IMAGE=openrlhf-rlvr
export TAG=v0.9.0.latest

# ---------------------------------------------------------------------------
# Cluster Details
#
# Two reference configurations are shown below:
#   - p5en.48xlarge: 8 x H100 80GB, 16 EFA, GPUDirect RDMA
#   - g5.12xlarge:   4 x A10G 24GB, 1 EFA, no GPUDirect RDMA
#
# Uncomment the block that matches your instance type.
# ---------------------------------------------------------------------------

export EKS_CLUSTER_NAME="<your-eks-cluster-name>"

# --- p5en.48xlarge configuration (default — high-end training) ---------------
# export INSTANCE_TYPE="p5en.48xlarge"
# export NUM_NODES=4
# export NUM_GPU_PER_NODE=8
# export NUM_EFA_PER_NODE=16
# export FI_EFA_USE_DEVICE_RDMA=1       # GPUDirect RDMA supported on p5/p5en
# export HEAD_CPU=8
# export HEAD_MEMORY=32Gi
# export WORKER_CPU=48
# export WORKER_MEMORY=400Gi
# export NCCL_PROTO=                     # Leave default (LL/LL128 auto-selected)

# --- g5.12xlarge configuration (cost-effective, 24GB GPUs) -------------------
export INSTANCE_TYPE="g5.12xlarge"
export NUM_NODES=5                      # 5 GPU workers (head pod has num-gpus=0)
export NUM_GPU_PER_NODE=4               # 4 x A10G per node
export NUM_EFA_PER_NODE=1               # 1 EFA device per node
export FI_EFA_USE_DEVICE_RDMA=0         # No GPUDirect RDMA on g5 — MUST be 0
export HEAD_CPU=4
export HEAD_MEMORY=8Gi                  # Head runs Ray driver only, no training
export WORKER_CPU=16                    # g5.12xlarge has ~48 allocatable CPUs
export WORKER_MEMORY=160Gi              # g5.12xlarge has ~172Gi allocatable
export NCCL_PROTO=simple                # Required for EFA without GPUDirect RDMA

export PRIVATE_SUBNET_ID="subnet-xxxxxxxxxxxxxxxxx"
export SECURITY_GROUP_ID="sg-xxxxxxxxxxxxxxxxx"


# Ray configs
export MODEL_NAME="gpt-oss-20b"
export MODEL_PATH="/fsx/models/gpt-oss-20b-sft-merged"  # SFT checkpoint (GRPO starts from SFT)
export RAY_DATA_HOME="/fsx/openrlhf"   # Shared storage for checkpoints and data
export RAY_DASHBOARD_PORT=8265
export RAY_ADDRESS="http://localhost:${RAY_DASHBOARD_PORT}"
export RAY_NAMESPACE="default"

# Job Env Vars
export HF_TOKEN=<your-huggingface-token>
export GPUS_PER_NODE=${NUM_GPU_PER_NODE}
export NCCL_DEBUG=INFO
export RAY_memory_usage_threshold=0.85

# ---------------------------------------------------------------------------
# Training parameters for OpenRLHF GRPO
#
# Key differences from veRL:
#   - OpenRLHF uses DeepSpeed ZeRO-3 (not FSDP)
#   - Non-Hybrid Engine: vLLM on 1 dedicated worker, training on 4 workers
#   - No critic model needed for GRPO (critic-free algorithm)
#   - Checkpoints saved in HuggingFace format directly (no merger step)
#
# Memory constraints (4 x A10G 24GB per node, 6 nodes total):
#   - ZeRO-3 + adam_offload + gradient_checkpointing
#   - Non-Hybrid: vLLM gets 1 node (4 GPUs), training gets 4 nodes (16 GPUs)
#   - adam_offload CPU: ~80GB/node (320GB / 16 GPUs × 4 GPUs/node)
#   - 160Gi worker pods → ~80GB headroom for checkpoint save/restore
#   - enforce_eager: no CUDA graphs (saves GPU memory)
#   - n_samples_per_prompt=2: conservative for memory
# ---------------------------------------------------------------------------

# Batch sizes
export ROLLOUT_BATCH_SIZE=16            # Prompts per rollout iteration
export TRAIN_BATCH_SIZE=32              # rollout_batch_size * n_samples_per_prompt
export N_SAMPLES_PER_PROMPT=2           # K=2 responses per prompt (required for GRPO)
export MICRO_TRAIN_BATCH_SIZE=1         # Per-GPU micro batch for training
export MICRO_ROLLOUT_BATCH_SIZE=1       # Per-GPU micro batch for rollout

# Reward function (must be on shared FSx, accessible by all Ray workers)
export REWARD_FN_PATH="/fsx/openrlhf/reward/language_reward.py"

# Checkpoint management
export SAVE_STEPS=20                    # Save every 20 steps
export MAX_CKPT_NUM=3                   # Keep max 3 checkpoints
export NUM_EPISODES=1                   # Number of passes over the dataset
export MAX_SAMPLES=1280                 # ~80 steps * 16 rollout_batch_size

# Managed Tiered Checkpointing with HyperPod (optional)
export S3_BUCKET_NAME="<your S3 bucket name>"
export S3_BUCKET_ARN="arn:aws:s3:::${S3_BUCKET_NAME}"
export S3_CHECKPOINT_BASE="s3://${S3_BUCKET_NAME}/checkpoints"
