# ============================================================================
# Isaac Lab on AWS - Configuration
# ============================================================================
# Copy this file to config.yaml and fill in your environment-specific values.
# Then run: python generate.py
# This generates ready-to-apply Kubernetes manifests and launch scripts.
# ============================================================================

# ---------------------------------------------------------------------------
# Common AWS settings
# ---------------------------------------------------------------------------
aws:
  account_id: ""                  # e.g. "123456789012"
  region: "us-east-1"

ecr:
  repository: "isaaclab-sagemaker"
  tag: "5.1.0"

s3:
  bucket: ""                      # e.g. "my-isaaclab-bucket"

# ---------------------------------------------------------------------------
# Isaac Lab training settings
# ---------------------------------------------------------------------------
training:
  task: "Isaac-Velocity-Rough-H1-v0"
  max_iterations: 1000
  framework: "skrl"               # skrl | rsl_rl | rl_games | sb3

# ---------------------------------------------------------------------------
# HyperPod EKS configuration
# ---------------------------------------------------------------------------
hyperpod_eks:
  # Container image (derived from aws.account_id + aws.region + ecr.* if left empty)
  image: ""                       # Override full image URI, or leave empty to auto-derive

  # Persistent storage PVC name (must exist in the cluster)
  storage:
    fsx_pvc_name: "isaaclab-fsx-pvc"

  # Storage provisioning details (used by storage manifest templates)
  fsx:
    file_system_id: ""            # e.g. "fs-0abc1234def56789"
    dns_name: ""                  # e.g. "fs-0abc1234.fsx.us-east-1.amazonaws.com"
    mount_name: ""                # e.g. "abcd1234"
    capacity: "1200Gi"

  # Node selectors
  node_health_label: "sagemaker.amazonaws.com/node-health-status"
  node_health_value: "Schedulable"

  # Job configuration
  jobs:
    training_job:
      instance_type: "ml.g6.12xlarge"
      gpus_per_node: 4
      num_nodes: 2                 # set to 1 for single node training
      memory_limit: "80Gi"
      memory_request: "64Gi"
      cpu_limit: "24"
      cpu_request: "16"
      shm_size: "16Gi"
      efa_per_node: 1               # EFA interfaces per node (set 0 to disable)
      fsx_log_dir: "/fsx/isaaclab-h1/logs"

# ---------------------------------------------------------------------------
# SageMaker Training Jobs configuration
# ---------------------------------------------------------------------------
sagemaker_training:
  role_arn: ""                    # e.g. "arn:aws:iam::123456789012:role/SageMakerRole"
  instance_type: "ml.g6.12xlarge"
  instance_count: 2
  volume_size_gb: 200
  max_runtime_seconds: 7200

  # S3 paths (derived from s3.bucket if left empty)
  scripts_s3_uri: ""              # e.g. "s3://bucket/scripts/sm-train-entrypoint.sh"
  output_s3_path: ""              # e.g. "s3://bucket/sm-training-output/"
  checkpoint_s3_path: ""          # e.g. "s3://bucket/sm-training-checkpoints/" — enables mid-training S3 sync and auto-resume
  checkpoint_prefix: ""           # e.g. "h1-rough-v1" — change per experiment to avoid accidental resume from a different run

  environment:
    NCCL_DEBUG: "INFO"

# ---------------------------------------------------------------------------
# Visualization pod
# ---------------------------------------------------------------------------
viz:
  gpu_instance_type: "ml.g6.12xlarge"
  num_envs: 25                       # parallel environments to replay in the viewport
  fsx_log_dir: "/fsx/isaaclab-h1/logs"  # defaults to hyperpod_eks.jobs.training_job.fsx_log_dir if unset

# ---------------------------------------------------------------------------
# MLflow (optional) - leave empty to disable.
# ---------------------------------------------------------------------------
mlflow:
  tracking_uri: ""                   # e.g. "arn:aws:sagemaker:<region>:<account>:mlflow-app/<id>"
  experiment_name: "isaaclab-h1"
  assume_role_arn: ""                # optional; set when tracking_uri is a Studio MLflow App
